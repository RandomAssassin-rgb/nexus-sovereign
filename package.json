{
  "name": "react-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "overrides": {
    "follow-redirects": "^1.15.12",
    "protobufjs": "^7.5.5"
  },
  "scripts": {
    "dev": "vite",
    "dev:vercel": "set VITE_DISABLE_BASIC_SSL=1&& vercel dev",
    "dev:server": "tsx server_dev.ts",
    "build": "vite build && node scripts/sync-style-fallback.mjs",
    "build:capacitor": "vite build --mode capacitor && node scripts/sync-style-fallback.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build:prod": "npm run build && npm run build:server",
    "start": "node dist-server/server_dev.js",
    "vercel-build": "npm run build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "cap:copy": "npm run build:capacitor && npx cap copy",
    "cap:sync": "npm run build:capacitor && npx cap sync",
    "cap:android": "npm run build:capacitor && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^8.0.0",
    "@capacitor/android": "^7.4.3",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/core": "^7.4.3",
    "@capacitor/geolocation": "^7.1.0",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.2",
    "@emotion/is-prop-valid": "^1.4.0",
    "@google/genai": "^1.50.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.38.0",
    "h3-js": "^4.4.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mapbox-gl": "^3.20.0",
    "motion": "^12.23.24",
    "openai": "^6.33.0",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^7.1.9",
    "react-router-dom": "^7.13.2",
    "react-webcam": "^7.2.0",
    "selfsigned": "^5.5.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.7.12",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^51.8.0",
    "vite": "^8.0.9"
  }
}
