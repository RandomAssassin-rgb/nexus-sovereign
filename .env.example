# Nexus Sovereign - Environment Configuration Example

# --- FRONTEND (Vite / Public) ---
VITE_API_BASE_URL=
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID

# --- BACKEND (Serverless / Private) ---
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
ADMIN_SECRET_KEY=nexus-master-gate
ADMIN_EMAIL=admin@nexus-sovereign.com

# --- EXTERNAL APIS ---
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
# WEATHER_API_KEY= (if using third-party weather)
# GOOGLE_MAPS_KEY= (if using for location search)
