{
  "$schema": "https://nexus-sovereign.guidewirecloud.com/schemas/claimcenter/v1",
  "metadata": {
    "payload_version": "1.0.0",
    "classification": "HARDENED",
    "tee_attested": true,
    "attestation_token_ttl_seconds": 90,
    "submitted_at": "{{ISO_TIMESTAMP}}"
  },
  "claim": {
    "claim_id": "{{CLAIM_ID}}",
    "policy_number": "{{POLICY_NUMBER}}",
    "claimant": {
      "name": "{{CLAIMANT_NAME}}",
      "identity_anchor": "{{GAUTH_UID}}",
      "android_attestation_cert": "{{PLAY_INTEGRITY_CERT}}"
    },
    "incident": {
      "type": "AUTO_COLLISION",
      "date": "{{INCIDENT_DATE}}",
      "location": {
        "h3_index": "{{H3_RESOLUTION_11_INDEX}}",
        "lat": "{{LATITUDE}}",
        "lng": "{{LONGITUDE}}"
      },
      "description": "{{INCIDENT_DESCRIPTION}}"
    },
    "financial": {
      "estimated_loss_usd": "{{ESTIMATED_LOSS}}",
      "deductible_usd": "{{DEDUCTIBLE}}",
      "currency": "USD"
    },
    "stp_flags": {
      "auto_approve_eligible": false,
      "sentinel_edge_cleared": true,
      "p_max_solvency_check": "PASSED",
      "autopilot_remediation_active": false
    }
  }
}
