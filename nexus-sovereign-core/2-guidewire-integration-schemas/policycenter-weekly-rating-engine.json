{
  "$schema": "https://nexus-sovereign.guidewirecloud.com/schemas/policycenter/rating-engine/v1",
  "metadata": {
    "payload_version": "1.0.0",
    "schedule": "WEEKLY",
    "run_day": "MONDAY",
    "run_time_utc": "00:00",
    "triggered_at": "{{ISO_TIMESTAMP}}"
  },
  "rating_engine": {
    "engine_version": "3.2.1",
    "algorithm": "DYNAMIC_ACTUARIAL_SCALING",
    "parameters": {
      "base_rate_multiplier": 1.0,
      "h3_risk_weight": 0.35,
      "sentinel_anomaly_weight": 0.25,
      "market_index_weight": 0.20,
      "claims_history_weight": 0.20
    },
    "p_max_constraint": {
      "enabled": true,
      "max_premium_increase_pct": 15.0,
      "solvency_floor_ratio": 1.25
    },
    "scope": {
      "policy_lines": ["AUTO", "PROPERTY", "COMMERCIAL"],
      "include_renewals": true,
      "include_new_business": true
    },
    "output": {
      "target_system": "PolicyCenter",
      "notify_underwriters": true,
      "audit_log_to_siem": true
    }
  }
}
